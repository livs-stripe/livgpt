# --- Agent (this app) Stripe account ---
# Used for the Delegated Checkout (Agentic Commerce) API calls.
STRIPE_SECRET_KEY=sk_test_your_agent_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_agent_publishable_key

# --- Seller / merchant account(s) ---
# For a LIVE (sandbox) demo you provide two non-secret values PER MERCHANT:
#   1) their Stripe profile id  -> charged server-side (shows in their Dashboard)
#   2) their publishable key    -> tokenizes the card client-side (Stripe Elements)
# You do NOT put any merchant SECRET key here; the agent uses its own
# STRIPE_SECRET_KEY above and passes each merchant's profile id as seller_profile_id.
#
# The demo catalog ships with these placeholder catalog seller ids (use them as
# the KEYS in both JSON maps below):
#   profile_harbor_and_home, profile_lumen_beauty, profile_northwind_apparel,
#   profile_summit_outdoors, profile_voltedge_electronics
#
# Map catalog seller id -> the merchant's REAL sandbox Stripe profile id.
# (Point several catalog merchants at the same real profile if you only have a
# few sandbox accounts.) Unmapped sellers fall back to SELLER_PROFILE_ID.
#   {"profile_harbor_and_home":"profile_realA","profile_lumen_beauty":"profile_realB"}
SELLER_PROFILE_IDS=
# Map catalog seller id -> that merchant's sandbox publishable key.
#   {"profile_harbor_and_home":"pk_test_A","profile_lumen_beauty":"pk_test_B"}
NEXT_PUBLIC_SELLER_PUBLISHABLE_KEYS=
# Single-seller fallbacks (used when a product's seller isn't in the maps above):
NEXT_PUBLIC_SELLER_PUBLISHABLE_KEY=pk_test_your_seller_publishable_key
SELLER_PROFILE_ID=profile_your_seller_profile_id

# --- Webhooks ---
# Agent (OCA lifecycle) webhook signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_agent_webhook_secret
# Optional: seller (checkout.session.completed) webhook signing secret.
# Falls back to STRIPE_WEBHOOK_SECRET if unset.
STRIPE_SELLER_WEBHOOK_SECRET=whsec_your_seller_webhook_secret

# --- Stripe API version ---
# Must be a preview version for Agentic Commerce.
STRIPE_API_VERSION=2025-12-15.preview

# --- Product feed (SFTP) ---
# The SFTP host Stripe delivers the seller's product feeds to (your AWS Transfer
# Family server, configured under "Receive product feeds"). This app connects as
# an SFTP client to download the manifest + .csv.gz catalog shards.
# NOTE: SFTP uses port 22, which the v0 preview sandbox blocks — the catalog is
# only populated when deployed to Vercel (or any host allowing outbound SSH).
SFTP_HOST=s-xxxxxxxx.server.transfer.us-east-1.amazonaws.com
SFTP_PORT=22
SFTP_USERNAME=stripefeeds
# Provide ONE auth method. Paste the full PRIVATE key (BEGIN/END included).
SFTP_PRIVATE_KEY=
SFTP_PASSWORD=
# Remote directory where Stripe drops the feed files (Transfer Family home dir).
SFTP_FEED_PATH=/

# --- Demo catalog fallback ---
# When SFTP isn't configured (or a feed returns no products), the app serves a
# bundled multi-merchant demo catalog (750 products across 5 merchants, with
# images under /public/mock-catalog/images). Set to "off" to disable and force
# a real feed / empty state instead.
MOCK_CATALOG=on

# --- OpenAI ---
OPENAI_API_KEY=sk_your_openai_api_key

# --- App ---
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
