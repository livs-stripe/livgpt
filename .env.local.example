# --- Agent (this app) Stripe account ---
# Used for the Delegated Checkout (Agentic Commerce) API calls.
STRIPE_SECRET_KEY=sk_test_your_agent_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_agent_publishable_key

# --- Seller / merchant account(s) ---
# For a LIVE (sandbox) demo you only need each merchant's Stripe PROFILE ID.
# Delegated Checkout collects the card with the AGENT's publishable key
# (NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY above) and mints a Shared Payment Token
# scoped to the seller at confirm time, so NO per-merchant keys are required.
# (This requires a confirmed OCA between your agent and each merchant.)
#
# The demo catalog ships with these placeholder catalog seller ids (use them as
# the KEYS in the map below):
#   profile_harbor_and_home, profile_lumen_beauty, profile_northwind_apparel,
#   profile_summit_outdoors, profile_voltedge_electronics
#
# Map catalog seller id -> the merchant's REAL sandbox Stripe profile id.
# Unmapped sellers fall back to SELLER_PROFILE_ID. Example:
#   {"profile_lumen_beauty":"profile_test_xxx","profile_summit_outdoors":"profile_test_yyy"}
SELLER_PROFILE_IDS=
# Single-seller fallback profile (used when a product's seller isn't in the map).
SELLER_PROFILE_ID=profile_your_seller_profile_id

# --- Webhooks ---
# Agent (OCA lifecycle) webhook signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_agent_webhook_secret
# Optional: seller (checkout.session.completed) webhook signing secret.
# Falls back to STRIPE_WEBHOOK_SECRET if unset.
STRIPE_SELLER_WEBHOOK_SECRET=whsec_your_seller_webhook_secret

# --- Stripe API version ---
# Must be the preview version the Delegated Checkout (Agentic Commerce) API is
# served under. The requested_sessions endpoints require this exact version;
# using a different preview date returns "Unrecognized request URL".
STRIPE_API_VERSION=2026-04-22.preview

# --- Product feed (SFTP) ---
# The SFTP endpoint Stripe delivers the seller's product feeds to. In this repo
# that endpoint is the SFTPGo server in ./sftp-server, deployed to Fly.io (see
# sftp-server/README.md). Stripe writes to it as the "stripe" user; this app
# connects as the read-only "app" user to download the manifest + CSV(.gz)
# catalog shards. (Any SFTP host works — SFTPGo/Fly is just what we ship.)
# NOTE: SFTP uses port 22, which the v0 preview sandbox blocks — the catalog is
# only populated when deployed to Vercel (or any host allowing outbound SSH).
SFTP_HOST=your-sftp-endpoint            # e.g. the Fly dedicated IPv4 from `fly ips list`
SFTP_PORT=22
SFTP_USERNAME=app                       # the read-only reader user (APP_SFTP_USERNAME)
# Provide ONE auth method. Paste the full PRIVATE key (BEGIN/END included) —
# the private half of the app user's key (sftp-server/app_key), not the .pub.
SFTP_PRIVATE_KEY=
SFTP_PASSWORD=
# Passphrase for SFTP_PRIVATE_KEY, only if the key is encrypted. Leave empty
# for a passphrase-less key.
SFTP_PASSPHRASE=
# Remote directory where Stripe drops the feed files (the SFTP root).
SFTP_FEED_PATH=/

# --- Demo catalog fallback ---
# When SFTP isn't configured (or a feed returns no products), the app serves a
# bundled multi-merchant demo catalog (750 products across 5 merchants, with
# images under /public/mock-catalog/images). Set to "off" to disable and force
# a real feed / empty state instead.
MOCK_CATALOG=on

# --- OpenAI ---
OPENAI_API_KEY=sk_your_openai_api_key

# --- App ---
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
