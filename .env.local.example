# --- Agent (this app) Stripe account ---
# Used for the Delegated Checkout (Agentic Commerce) API calls.
STRIPE_SECRET_KEY=sk_test_your_agent_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_agent_publishable_key

# --- Seller account ---
# Stripe Elements on the client are initialized with the SELLER's publishable key.
NEXT_PUBLIC_SELLER_PUBLISHABLE_KEY=pk_test_your_seller_publishable_key
# The seller profile your agent transacts against.
SELLER_PROFILE_ID=profile_your_seller_profile_id

# --- Webhooks ---
# Agent (OCA lifecycle) webhook signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_agent_webhook_secret
# Optional: seller (checkout.session.completed) webhook signing secret.
# Falls back to STRIPE_WEBHOOK_SECRET if unset.
STRIPE_SELLER_WEBHOOK_SECRET=whsec_your_seller_webhook_secret

# --- Stripe API version ---
# Must be a preview version for Agentic Commerce.
STRIPE_API_VERSION=2025-12-15.preview

# --- Product feed (SFTP) ---
# The SFTP host Stripe delivers the seller's product feeds to (your AWS Transfer
# Family server, configured under "Receive product feeds"). This app connects as
# an SFTP client to download the manifest + .csv.gz catalog shards.
# NOTE: SFTP uses port 22, which the v0 preview sandbox blocks — the catalog is
# only populated when deployed to Vercel (or any host allowing outbound SSH).
SFTP_HOST=s-xxxxxxxx.server.transfer.us-east-1.amazonaws.com
SFTP_PORT=22
SFTP_USERNAME=stripefeeds
# Provide ONE auth method. Paste the full PRIVATE key (BEGIN/END included).
SFTP_PRIVATE_KEY=
SFTP_PASSWORD=
# Remote directory where Stripe drops the feed files (Transfer Family home dir).
SFTP_FEED_PATH=/

# --- OpenAI ---
OPENAI_API_KEY=sk_your_openai_api_key

# --- App ---
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
